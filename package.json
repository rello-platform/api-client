{
  "name": "@rello-platform/api-client",
  "version": "1.7.0",
  "description": "Unified API client for Rello platform spoke apps",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "openapi:generate": "npx openapi-typescript ../Rello/public/openapi.json -o src/generated/api-types.ts",
    "openapi:generate-remote": "npx openapi-typescript https://hellorello.app/api/openapi -o src/generated/api-types.ts"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rello-platform/api-client.git"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
